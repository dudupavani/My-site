# ---------------------------------------------------------------------------
# Supabase
# ---------------------------------------------------------------------------
SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_STORAGE_BUCKET_BLOG_COVERS=blog-post-covers

# Must be at least 2× the page revalidate interval (revalidate=3600s).
# Prevents cached pages from serving expired cover image URLs.
SUPABASE_SIGNED_URL_TTL_SECONDS=7200

# ---------------------------------------------------------------------------
# Admin authentication
# ---------------------------------------------------------------------------
# PRODUCTION: use "supabase_jwt" or "static_token" — never leave "off" in prod.
# DEVELOPMENT: "off" disables auth checks entirely (safe only locally).
BLOG_ADMIN_AUTH_MODE=off

# Required when BLOG_ADMIN_AUTH_MODE=supabase_jwt
# Comma-separated list of allowed email addresses
BLOG_ADMIN_ALLOWED_EMAILS=admin@example.com

# Required when BLOG_ADMIN_AUTH_MODE=static_token
# Comma-separated list of valid tokens
BLOG_ADMIN_STATIC_TOKENS=

# ---------------------------------------------------------------------------
# CKEditor
# ---------------------------------------------------------------------------
NEXT_PUBLIC_CKEDITOR_LICENSE_KEY=GPL
