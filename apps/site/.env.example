SUPABASE_URL=https://<your-project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_STORAGE_BUCKET_BLOG_COVERS=blog-post-covers
SUPABASE_SIGNED_URL_TTL_SECONDS=3600

# Admin API auth rollout
# off (default) | supabase_jwt | static_token
BLOG_ADMIN_AUTH_MODE=off
# Required for supabase_jwt
BLOG_ADMIN_ALLOWED_EMAILS=admin@example.com
# Required for static_token (comma-separated)
BLOG_ADMIN_STATIC_TOKENS=

# CKEditor
NEXT_PUBLIC_CKEDITOR_LICENSE_KEY=GPL
